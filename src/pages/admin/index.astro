---
import { CMS, SITE } from '../../config';

export const prerender = true;

const quickLinks = [
  { label: '返回博客', href: '/', external: false },
  { label: '英文首页', href: '/en', external: false },
  { label: 'GitHub 仓库', href: `https://github.com/${CMS.repo}`, external: true },
];

const notes = [
  `文章会提交到 ${CMS.repo} 的 ${CMS.branch} 分支`,
  '图片会上传到 public/images/uploads',
  '发布后 Cloudflare Workers 会自动重新部署',
];

const adminRuntime = JSON.stringify({
  repo: CMS.repo,
  branch: CMS.branch,
  mediaFolder: CMS.mediaFolder,
  publicFolder: CMS.publicFolder,
});
const adminAssetVersion = '20260715-editor-controls-3';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>{SITE.name} · 后台管理</title>
    <link rel="icon" href="/favicon.ico?v=20260713-avatar" sizes="any" />
    <link rel="icon" type="image/png" sizes="256x256" href="/images/a1right-avatar-icon.png?v=20260713-avatar" />
    <link href="/admin/config.yml" type="text/yaml" rel="cms-config-url" />
    <link rel="stylesheet" href={`/admin/custom.css?v=${adminAssetVersion}`} />
    <script is:inline define:vars={{ adminRuntime }}>
      window.__A1RIGHT_ADMIN__ = JSON.parse(adminRuntime);
    </script>
    <script is:inline src="/admin/vendor/marked.umd.js" defer></script>
    <script is:inline src="/admin/vendor/purify.min.js" defer></script>
    <script is:inline src={`/admin/custom.js?v=${adminAssetVersion}`} defer></script>
    <style>
      :root {
        color-scheme: light;
        --mint: #20bd91;
        --mint-deep: #109875;
        --mint-soft: #ebf9f4;
        --ink: #202726;
        --muted: #6f7b77;
        --line: rgba(25, 77, 62, 0.1);
        --card: rgba(255, 255, 255, 0.9);
        --shadow: 0 24px 70px rgba(21, 52, 43, 0.2);
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; min-height: 100%; font-family: var(--font-sans, 'Noto Sans SC', 'Microsoft YaHei', sans-serif); }
      body {
        color: var(--ink);
        background: #e9f3ef;
      }
      body:not(.admin-shell--cms-active) {
        background:
          linear-gradient(rgba(14, 25, 31, .42), rgba(14, 25, 31, .5)),
          url('/images/anime-hero-room.jpg') center / cover fixed no-repeat;
      }

      .admin-login { min-height: 100vh; padding: 0 22px 38px; }
      .admin-login__navbar {
        width: min(1180px, 100%); min-height: 68px; margin: 0 auto;
        padding: 0 24px; display: flex; align-items: center; justify-content: space-between; gap: 18px;
        border: 1px solid rgba(255,255,255,.45); border-top: 0; border-radius: 0 0 16px 16px;
        background: rgba(255,255,255,.82); box-shadow: 0 4px 18px rgba(0,0,0,.1); backdrop-filter: blur(18px);
      }
      .admin-login__brand { display: flex; align-items: center; gap: 9px; font-weight: 850; }
      .admin-login__brand span { font-family: var(--font-display, 'Noto Sans SC', 'Microsoft YaHei', sans-serif); font-weight: 700; letter-spacing: .015em; }
      .admin-login__brand img { width: 34px; height: 34px; border-radius: 10px; object-fit: cover; object-position: center; box-shadow: 0 8px 20px rgba(16, 152, 117, .16); }
      .admin-login__navlinks { display: flex; gap: 8px; }
      .admin-login__navlinks a { padding: 8px 12px; border-radius: 9px; color: var(--muted); font-size: .84rem; font-weight: 700; text-decoration: none; }
      .admin-login__navlinks a:hover { color: var(--mint-deep); background: var(--mint-soft); }

      .admin-login__frame { width: min(980px, 100%); margin: 80px auto 0; }
      .admin-login__card {
        overflow: hidden; display: grid; grid-template-columns: 330px minmax(0, 1fr);
        border: 1px solid rgba(255,255,255,.55); border-radius: 20px;
        background: var(--card); box-shadow: var(--shadow); backdrop-filter: blur(20px);
      }
      .admin-login__profile { padding: 22px; border-right: 1px solid var(--line); text-align: center; }
      .admin-login__avatar { width: 100%; aspect-ratio: 1; border-radius: 14px; object-fit: cover; object-position: center; }
      .admin-login__profile h2 { margin: 18px 0 0; font-size: 1.55rem; }
      .admin-login__profile-line { display: block; width: 48px; height: 4px; margin: 9px auto 0; border-radius: 99px; background: var(--mint); }
      .admin-login__profile p { margin: 13px 0 0; color: var(--muted); font-size: .9rem; line-height: 1.7; }
      .admin-login__profile-icons { display: grid; grid-template-columns: repeat(3, 1fr); gap: 9px; margin-top: 18px; }
      .admin-login__profile-icons span { height: 40px; display: grid; place-items: center; border-radius: 10px; background: var(--mint-soft); color: var(--mint-deep); font-weight: 800; }

      .admin-login__content { padding: 44px; display: flex; flex-direction: column; justify-content: center; }
      .admin-login__badge { align-self: flex-start; padding: 7px 12px; border-radius: 999px; background: var(--mint-soft); color: var(--mint-deep); font-size: .8rem; font-weight: 800; }
      .admin-login__title { margin: 18px 0 0; font-size: clamp(2rem, 4vw, 2.8rem); line-height: 1.15; }
      .admin-login__summary { margin: 14px 0 0; color: var(--muted); line-height: 1.8; }
      .admin-login__meta { margin-top: 20px; display: flex; flex-wrap: wrap; gap: 8px; }
      .admin-login__meta span { padding: 7px 10px; border-radius: 8px; background: #f5f8f7; color: var(--muted); font-size: .78rem; }
      .admin-login__cta { margin-top: 24px; display: grid; gap: 10px; }
      .admin-login__trigger { min-height: 48px; padding: 0 20px; border: 0; border-radius: 11px; background: var(--mint); color: #fff; font: inherit; font-weight: 850; cursor: pointer; box-shadow: 0 12px 26px rgba(32,189,145,.24); }
      .admin-login__trigger:hover:not(:disabled) { background: #28c99b; transform: translateY(-1px); }
      .admin-login__trigger:disabled { opacity: .55; cursor: wait; }
      .admin-login__status { margin: 0; color: var(--muted); font-size: .84rem; }
      .admin-login__notes { margin: 20px 0 0; padding: 15px 16px 15px 32px; border: 1px solid var(--line); border-radius: 12px; background: rgba(238,248,244,.7); color: var(--muted); font-size: .82rem; }
      .admin-login__notes li + li { margin-top: 7px; }

      #nc-root { min-height: 100vh; }
      body:not(.admin-shell--cms-active) #nc-root { position: fixed; inset: 0; opacity: 0; pointer-events: none; }
      body.admin-shell--cms-active .admin-login { display: none; }
      body.admin-shell--cms-active #nc-root { position: relative; opacity: 1; pointer-events: auto; }

      @media (max-width: 760px) {
        .admin-login { padding: 0 12px 24px; }
        .admin-login__navbar { padding: 0 14px; }.admin-login__navlinks a:nth-child(2) { display: none; }
        .admin-login__frame { margin-top: 28px; }.admin-login__card { grid-template-columns: 1fr; }
        .admin-login__profile { border-right: 0; border-bottom: 1px solid var(--line); }
        .admin-login__avatar { max-height: 260px; }.admin-login__content { padding: 28px 22px; }
      }
    </style>
  </head>
  <body>
    <div class="admin-login" id="admin-login-shell">
      <header class="admin-login__navbar">
        <div class="admin-login__brand"><img src="/images/a1right-avatar-icon.png?v=20260713-avatar" alt="" aria-hidden="true" /><span>{SITE.name}</span></div>
        <nav class="admin-login__navlinks">
          {quickLinks.map((item) => <a href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noreferrer' : undefined}>{item.label}</a>)}
        </nav>
      </header>

      <main class="admin-login__frame">
        <section class="admin-login__card">
          <div class="admin-login__profile">
            <img class="admin-login__avatar" src="/images/a1right-avatar.png" alt={SITE.author} />
            <h2>{SITE.author}</h2><i class="admin-login__profile-line"></i>
            <p>学生 · 安全学习者<br />Web 安全 / CTF / Agent 渗透</p>
            <div class="admin-login__profile-icons"><span>▤</span><span>⌘</span><span>#</span></div>
          </div>

          <div class="admin-login__content">
            <div class="admin-login__badge">FIREFLY · CONTENT STUDIO</div>
            <h1 class="admin-login__title">登录博客后台</h1>
            <p class="admin-login__summary">通过 GitHub 登录后，可以在线写文章、上传图片并发布中英文安全笔记。</p>
            <div class="admin-login__meta"><span>{CMS.repo}</span><span>{CMS.branch}</span><span>Decap CMS</span></div>
            <div class="admin-login__cta">
              <button class="admin-login__trigger" id="admin-login-trigger" type="button" disabled>使用 GitHub 登录</button>
              <p class="admin-login__status" id="admin-login-status">正在加载后台登录模块…</p>
            </div>
            <ul class="admin-login__notes">{notes.map((item) => <li>{item}</li>)}</ul>
          </div>
        </section>
      </main>
    </div>

    <div id="nc-root"></div>
    <noscript>需要启用 JavaScript 才能使用后台发文页面。</noscript>

    <script is:inline>
      const loginTrigger = document.getElementById('admin-login-trigger');
      const loginStatus = document.getElementById('admin-login-status');
      const cmsRoot = document.getElementById('nc-root');
      let cmsHasEnteredApp = false;

      const translations = new Map([
        ['Content', '文章管理'], ['Media', '图片库'], ['Collections', '内容栏目'],
        ['New Chinese Post', '新建中文文章'], ['New English Post', '新建英文文章'],
      ]);
      const attributeTranslations = new Map([
        ['Account options dropdown', '账户菜单'], ['List view option', '列表视图'], ['Grid view option', '卡片视图'],
        ['Strikethrough', '删除线'], ['Set publishedAt to now', '将发布日期设为现在'], ['Set updatedAt to now', '将更新日期设为现在'],
      ]);

      const syncRouteClass = () => {
        const hash = window.location.hash;
        document.body.classList.toggle('admin-route--editor', /\/(new|entries\/)/.test(hash));
        document.body.classList.toggle('admin-route--collection', hash.startsWith('#/collections/') && !/\/(new|entries\/)/.test(hash));
        document.body.classList.toggle('admin-route--dashboard', hash === '#/' || hash === '');
      };

      const localizeCmsUI = () => {
        if (!cmsRoot) return;
        cmsRoot.querySelectorAll('[aria-label], [title]').forEach((element) => {
          ['aria-label', 'title'].forEach((attribute) => {
            const current = element.getAttribute(attribute);
            const translated = current ? attributeTranslations.get(current) : null;
            if (translated) element.setAttribute(attribute, translated);
          });
        });
        const walker = document.createTreeWalker(cmsRoot, NodeFilter.SHOW_TEXT);
        const nodes = [];
        let node;
        while ((node = walker.nextNode())) nodes.push(node);
        nodes.forEach((textNode) => {
          const value = textNode.nodeValue?.trim();
          const translated = value ? translations.get(value) : null;
          if (translated) textNode.nodeValue = textNode.nodeValue.replace(value, translated);
        });
        syncRouteClass();
      };

      const findGithubButton = () => Array.from(cmsRoot?.querySelectorAll('button') ?? []).find((button) => /github|登录|log in/i.test(button.textContent ?? '')) ?? null;
      const cmsEditorReady = () => {
        const ready = Boolean(cmsRoot?.querySelector('aside')) || Boolean(cmsRoot?.querySelector('[class*="CollectionContainer"]')) || Boolean(cmsRoot?.querySelector('[class*="EditorContainer"]')) || Boolean(cmsRoot?.querySelector('[class*="ToolbarContainer"]'));
        if (ready) cmsHasEnteredApp = true;
        return cmsHasEnteredApp;
      };

      const syncAdminState = () => {
        localizeCmsUI();
        const githubButton = findGithubButton();
        const editorReady = cmsEditorReady();
        document.body.classList.toggle('admin-shell--cms-active', editorReady);
        if (editorReady) {
          loginTrigger?.setAttribute('disabled', 'disabled');
          if (loginStatus) loginStatus.textContent = '已进入后台';
        } else if (githubButton) {
          loginTrigger?.removeAttribute('disabled');
          if (loginStatus) loginStatus.textContent = '后台连接完成，可以开始 GitHub 授权';
        } else {
          loginTrigger?.setAttribute('disabled', 'disabled');
          if (loginStatus) loginStatus.textContent = '正在加载后台登录模块…';
        }
      };

      loginTrigger?.addEventListener('click', () => {
        const githubButton = findGithubButton();
        if (!githubButton) { if (loginStatus) loginStatus.textContent = '登录模块还未准备好，请稍后再试'; return; }
        if (loginStatus) loginStatus.textContent = '正在打开 GitHub 授权窗口…';
        githubButton.click();
      });

      if (cmsRoot) new MutationObserver(syncAdminState).observe(cmsRoot, { childList: true, subtree: true, attributes: true });
      window.addEventListener('hashchange', () => window.setTimeout(syncAdminState, 60));
      syncAdminState();

      const decapScript = document.createElement('script');
      decapScript.src = 'https://unpkg.com/decap-cms@3.14.1/dist/decap-cms.js';
      decapScript.defer = true;
      decapScript.onload = syncAdminState;
      decapScript.onerror = () => { if (loginStatus) loginStatus.textContent = '后台模块加载失败，请刷新页面重试'; };
      document.body.append(decapScript);
      window.setInterval(syncAdminState, 1200);
    </script>
  </body>
</html>
