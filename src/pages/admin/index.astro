---
import { CMS, SITE } from '../../config';

export const prerender = true;

const quickLinks = [
  { label: '返回前台', href: '/', external: false },
  { label: '英文首页', href: '/en', external: false },
  { label: 'GitHub 仓库', href: `https://github.com/${CMS.repo}`, external: true },
];

const notes = [
  `文章会直接提交到 ${CMS.repo} 的 ${CMS.branch} 分支`,
  '图片会上传到 public/images/uploads',
  '发布完成后 Cloudflare 会自动重新部署',
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>{SITE.name} 后台登录</title>
    <link rel="stylesheet" href="/admin/custom.css" />
    <style>
      :root {
        color-scheme: dark;
        --login-bg: #0a0f1a;
        --login-surface: rgba(13, 19, 33, 0.84);
        --login-surface-soft: rgba(255, 255, 255, 0.06);
        --login-border: rgba(120, 169, 255, 0.18);
        --login-text: #eff4ff;
        --login-text-soft: rgba(239, 244, 255, 0.72);
        --login-accent: #8ddfff;
        --login-accent-strong: #85a5ff;
        --login-shadow: 0 22px 60px rgba(3, 6, 16, 0.5);
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        min-height: 100%;
        background:
          radial-gradient(circle at top left, rgba(98, 202, 255, 0.16), transparent 28%),
          radial-gradient(circle at top right, rgba(188, 142, 255, 0.18), transparent 34%),
          linear-gradient(180deg, #0f1524 0%, #0a0f1a 52%, #090d16 100%);
        color: var(--login-text);
        font-family: 'Noto Sans SC', 'Segoe UI', sans-serif;
      }

      body.admin-shell--cms-active {
        background: var(--login-bg);
      }

      .admin-login {
        min-height: 100vh;
        padding: 28px;
        display: grid;
        place-items: center;
      }

      .admin-login__frame {
        width: min(1080px, 100%);
        position: relative;
      }

      .admin-login__frame::before,
      .admin-login__frame::after {
        content: '';
        position: absolute;
        border-radius: 999px;
        filter: blur(48px);
        opacity: 0.72;
        z-index: 0;
      }

      .admin-login__frame::before {
        width: 180px;
        height: 180px;
        left: -36px;
        top: -30px;
        background: rgba(98, 202, 255, 0.24);
      }

      .admin-login__frame::after {
        width: 220px;
        height: 220px;
        right: -48px;
        bottom: -44px;
        background: rgba(167, 125, 255, 0.18);
      }

      .admin-login__card {
        position: relative;
        z-index: 1;
        overflow: hidden;
        display: grid;
        grid-template-columns: minmax(280px, 0.94fr) minmax(360px, 1.06fr);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 32px;
        background: rgba(11, 16, 28, 0.82);
        box-shadow: var(--login-shadow);
        backdrop-filter: blur(18px);
      }

      .admin-login__visual {
        position: relative;
        min-height: 620px;
        padding: 28px;
        display: flex;
        align-items: flex-end;
        background:
          linear-gradient(180deg, rgba(5, 8, 16, 0.06) 0%, rgba(5, 8, 16, 0.68) 68%, rgba(5, 8, 16, 0.92) 100%),
          url('/images/anime-hero-city.jpg') center / cover no-repeat;
      }

      .admin-login__visual::after {
        content: '';
        position: absolute;
        inset: 0;
        background:
          radial-gradient(circle at 22% 18%, rgba(141, 223, 255, 0.24), transparent 24%),
          linear-gradient(180deg, rgba(133, 165, 255, 0.06), transparent 22%);
      }

      .admin-login__avatar {
        position: relative;
        z-index: 1;
        width: 88px;
        height: 88px;
        border-radius: 28px;
        display: grid;
        place-items: center;
        font-size: 2.3rem;
        font-weight: 800;
        color: #f7fbff;
        background: linear-gradient(160deg, rgba(77, 209, 255, 0.32), rgba(152, 129, 255, 0.34));
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 18px 36px rgba(4, 10, 22, 0.34);
      }

      .admin-login__visual-copy {
        position: relative;
        z-index: 1;
        margin-left: 18px;
      }

      .admin-login__visual-copy p {
        margin: 0;
        color: rgba(239, 244, 255, 0.82);
        line-height: 1.7;
      }

      .admin-login__visual-copy strong {
        display: block;
        margin-bottom: 10px;
        font-size: 1.24rem;
        color: #f3f8ff;
      }

      .admin-login__content {
        padding: 42px;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .admin-login__badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        align-self: flex-start;
        min-height: 34px;
        padding: 0 14px;
        border-radius: 999px;
        background: rgba(141, 223, 255, 0.12);
        color: #b9eeff;
        font-size: 0.92rem;
        font-weight: 700;
      }

      .admin-login__title {
        margin: 18px 0 0;
        font-size: clamp(2.3rem, 5vw, 3.2rem);
        line-height: 1.08;
      }

      .admin-login__summary {
        margin: 16px 0 0;
        color: var(--login-text-soft);
        line-height: 1.8;
        font-size: 1.02rem;
      }

      .admin-login__meta {
        margin-top: 22px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .admin-login__meta span {
        display: inline-flex;
        align-items: center;
        min-height: 38px;
        padding: 0 14px;
        border-radius: 999px;
        background: var(--login-surface-soft);
        border: 1px solid rgba(255, 255, 255, 0.06);
        color: rgba(239, 244, 255, 0.86);
        font-size: 0.92rem;
      }

      .admin-login__cta {
        margin-top: 26px;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
      }

      .admin-login__trigger {
        min-width: 220px;
        min-height: 52px;
        padding: 0 22px;
        border: 0;
        border-radius: 999px;
        background: linear-gradient(135deg, #79dfff, #8a9eff 72%, #ab8cff);
        color: #08111f;
        font-weight: 800;
        font-size: 1rem;
        cursor: pointer;
        box-shadow: 0 16px 34px rgba(86, 144, 255, 0.32);
        transition: transform 160ms ease, filter 160ms ease, opacity 160ms ease;
      }

      .admin-login__trigger:hover:not(:disabled) {
        transform: translateY(-1px);
        filter: brightness(1.04);
      }

      .admin-login__trigger:disabled {
        opacity: 0.52;
        cursor: wait;
      }

      .admin-login__status {
        margin: 0;
        color: rgba(239, 244, 255, 0.68);
        font-size: 0.95rem;
      }

      .admin-login__links {
        margin-top: 24px;
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }

      .admin-login__link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        padding: 0 14px;
        border-radius: 999px;
        border: 1px solid var(--login-border);
        background: rgba(116, 148, 255, 0.08);
        color: #f4f8ff;
        font-weight: 700;
        text-decoration: none;
      }

      .admin-login__notes {
        margin: 24px 0 0;
        padding: 18px 18px 18px 20px;
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
        color: rgba(239, 244, 255, 0.8);
      }

      .admin-login__notes li + li {
        margin-top: 10px;
      }

      #nc-root {
        min-height: 100vh;
      }

      body:not(.admin-shell--cms-active) #nc-root {
        position: fixed;
        inset: 0;
        opacity: 0;
        pointer-events: none;
      }

      body.admin-shell--cms-active .admin-login {
        display: none;
      }

      body.admin-shell--cms-active #nc-root {
        position: relative;
        inset: auto;
        opacity: 1;
        pointer-events: auto;
      }

      @media (max-width: 920px) {
        .admin-login {
          padding: 18px;
        }

        .admin-login__card {
          grid-template-columns: 1fr;
        }

        .admin-login__visual {
          min-height: 300px;
        }
      }

      @media (max-width: 560px) {
        .admin-login__content,
        .admin-login__visual {
          padding: 22px;
        }

        .admin-login__title {
          font-size: 2rem;
        }

        .admin-login__meta,
        .admin-login__links {
          flex-direction: column;
        }

        .admin-login__link,
        .admin-login__trigger {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <div class="admin-login" id="admin-login-shell">
      <main class="admin-login__frame">
        <section class="admin-login__card">
          <div class="admin-login__visual">
            <div class="admin-login__avatar">{SITE.avatarText}</div>
            <div class="admin-login__visual-copy">
              <strong>{SITE.englishName}</strong>
              <p>轻量后台 + 二次元封面 + GitHub 同步发布</p>
            </div>
          </div>

          <div class="admin-login__content">
            <div class="admin-login__badge">Decap CMS · GitHub 后台</div>
            <h1 class="admin-login__title">{SITE.name} 后台登录</h1>
            <p class="admin-login__summary">
              登录后就能在线写文章、传图片、发布 Web 安全 / CTF / Agent 渗透内容。整体走轻量博客后台风格，但保留你现在的二次元气质。
            </p>

            <div class="admin-login__meta">
              <span>{CMS.repo}</span>
              <span>{CMS.branch}</span>
              <span>{SITE.provisionalUrl}</span>
            </div>

            <div class="admin-login__cta">
              <button class="admin-login__trigger" id="admin-login-trigger" type="button" disabled>
                使用 GitHub 登录
              </button>
              <p class="admin-login__status" id="admin-login-status">正在加载后台登录模块…</p>
            </div>

            <div class="admin-login__links">
              {quickLinks.map((item) => (
                <a
                  class="admin-login__link"
                  href={item.href}
                  target={item.external ? '_blank' : undefined}
                  rel={item.external ? 'noreferrer' : undefined}
                >
                  {item.label}
                </a>
              ))}
            </div>

            <ul class="admin-login__notes">
              {notes.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        </section>
      </main>
    </div>

    <div id="nc-root"></div>
    <noscript>需要启用 JavaScript 才能使用后台发文页面。</noscript>

    <script is:inline>
      const loginTrigger = document.getElementById('admin-login-trigger');
      const loginStatus = document.getElementById('admin-login-status');
      const cmsRoot = document.getElementById('nc-root');

      const findGithubButton = () => {
        const buttons = Array.from(cmsRoot?.querySelectorAll('button') ?? []);
        return buttons.find((button) => /github/i.test(button.textContent ?? '')) ?? null;
      };

      const cmsEditorReady = () => Boolean(cmsRoot?.querySelector('aside')) && Boolean(cmsRoot?.querySelector('main'));

      const syncAdminState = () => {
        const githubButton = findGithubButton();
        const editorReady = cmsEditorReady();

        document.body.classList.toggle('admin-shell--cms-active', editorReady);

        if (editorReady) {
          loginTrigger?.setAttribute('disabled', 'disabled');
          if (loginStatus) loginStatus.textContent = '已进入后台，正在展开编辑器…';
          return;
        }

        if (githubButton) {
          loginTrigger?.removeAttribute('disabled');
          if (loginStatus) loginStatus.textContent = '后台已连接完成，点击按钮开始 GitHub 授权。';
          return;
        }

        loginTrigger?.setAttribute('disabled', 'disabled');
        if (loginStatus) loginStatus.textContent = '正在加载后台登录模块…';
      };

      loginTrigger?.addEventListener('click', () => {
        const githubButton = findGithubButton();

        if (!githubButton) {
          if (loginStatus) loginStatus.textContent = '登录按钮还没准备好，稍等 1 秒再试。';
          syncAdminState();
          return;
        }

        if (loginStatus) loginStatus.textContent = '正在打开 GitHub 授权窗口…';
        githubButton.click();
      });

      const decapObserver = new MutationObserver(() => {
        syncAdminState();
      });

      if (cmsRoot) {
        decapObserver.observe(cmsRoot, {
          childList: true,
          subtree: true,
          attributes: true,
        });
      }

      syncAdminState();

      const decapScript = document.createElement('script');
      decapScript.src = 'https://unpkg.com/decap-cms@3.14.1/dist/decap-cms.js';
      decapScript.defer = true;
      decapScript.onload = () => syncAdminState();
      decapScript.onerror = () => {
        if (loginStatus) loginStatus.textContent = '后台登录模块加载失败，刷新页面后再试一次。';
      };

      document.body.append(decapScript);
      window.setInterval(syncAdminState, 1200);
    </script>
  </body>
</html>
