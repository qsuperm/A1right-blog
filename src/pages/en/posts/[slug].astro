---
import { render } from 'astro:content';
import PostLayout from '../../../layouts/PostLayout.astro';
import { getArticlesByLocale, getArticleUrl, getReadingMinutesFromText } from '../../../utils/articles';

export async function getStaticPaths() {
  const articles = await getArticlesByLocale('en');
  return articles.map((entry) => ({
    params: { slug: entry.data.routeSlug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const [allEn, allZh] = await Promise.all([getArticlesByLocale('en'), getArticlesByLocale('zh-cn')]);
const articleIndex = allEn.findIndex((item) => item.id === entry.id);
const previous = articleIndex < allEn.length - 1 ? allEn[articleIndex + 1] : undefined;
const next = articleIndex > 0 ? allEn[articleIndex - 1] : undefined;
const translation = allZh.find((item) => item.data.translationKey === entry.data.translationKey);
const { Content, headings } = await render(entry);
const readingMinutes = getReadingMinutesFromText(entry.body ?? "");
---

<PostLayout
  entry={entry}
  locale="en"
  headings={headings}
  Content={Content}
  readingMinutes={readingMinutes}
  previous={previous}
  next={next}
  alternatePath={translation ? getArticleUrl(translation) : undefined}
/>
