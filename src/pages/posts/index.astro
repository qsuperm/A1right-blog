---
import PostsArchivePage from '../../components/PostsArchivePage.astro';
import { getArticlesByLocale, getPaginatedArticleChunks } from '../../utils/articles';

const locale = 'zh-cn';
const allArticles = await getArticlesByLocale(locale);
const [firstPage] = getPaginatedArticleChunks(allArticles);
---

<PostsArchivePage
  locale={locale}
  currentPage={firstPage.currentPage}
  totalPages={firstPage.totalPages}
  articles={firstPage.items}
  allArticles={allArticles}
/>
