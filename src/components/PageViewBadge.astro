---
import type { Locale } from '../config';

interface Props {
  locale?: Locale;
  path?: string;
  total?: boolean;
  daily?: boolean;
  mode?: 'compact' | 'full' | 'value';
}

const {
  locale = 'zh-cn',
  path,
  total = false,
  daily = false,
  mode = 'compact',
} = Astro.props;

const label = locale === 'en' ? 'Views' : '浏览量';
const totalLabel = locale === 'en' ? 'Site views' : '总站浏览量';
const dailyLabel = locale === 'en' ? 'Today views' : '今日访问';
const resolvedPath = total ? undefined : path;
const resolvedScope = daily ? 'site-daily' : total ? 'site-total' : 'page';
const resolvedLabel = daily ? dailyLabel : total ? totalLabel : label;
---

<span
  class:list={[
    'pageview-badge',
    mode === 'compact' && 'pageview-badge--compact',
    mode === 'full' && 'pageview-badge--full',
    mode === 'value' && 'pageview-badge--value',
  ]}
  data-pageview-path={resolvedPath}
  data-pageview-scope={resolvedScope}
  data-pageview-label={resolvedLabel}
  aria-live="polite"
>
  <span class="pageview-badge__icon" aria-hidden="true">◔</span>
  <span class="pageview-badge__label">{resolvedLabel}</span>
  <strong class="pageview-badge__value">--</strong>
</span>
