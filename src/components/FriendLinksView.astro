---
import type { Locale } from '../config';
import { FRIEND_LINKS, FRIEND_PAGE_COPY } from '../data/friends';
import TaxonomyLayout from '../layouts/TaxonomyLayout.astro';
import { getFriendsUrl } from '../utils/articles';
import { buildCollectionPageJsonLd } from '../utils/seo';
import FriendLinkCard from './FriendLinkCard.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = FRIEND_PAGE_COPY[locale];
const title = copy.title;
const description = '';
const path = getFriendsUrl(locale);
const breadcrumbs =
  locale === 'en'
    ? [
        { label: 'Home', href: '/en' },
        { label: copy.navLabel, href: path },
      ]
    : [
        { label: '首页', href: '/' },
        { label: copy.navLabel, href: path },
      ];

const structuredData = buildCollectionPageJsonLd({
  title,
  description,
  path,
  locale,
});

const keywords =
  locale === 'en'
    ? ['friend links', 'personal blogroll', 'security blog', 'A1right']
    : ['友情链接', '博客友链', '网络安全博客', 'A1right'];

---

<TaxonomyLayout
  locale={locale}
  title={title}
  description={description}
  eyebrow="友链"
  stats={[`${FRIEND_LINKS.length} 位友邻`]}
  breadcrumbs={breadcrumbs}
  keywords={keywords}
  structuredData={structuredData}
>
  <section class="friends-shell">
    <div class="friends-grid">
      {FRIEND_LINKS.length > 0 ? (
        FRIEND_LINKS.map((item) => <FriendLinkCard locale={locale} item={item} />)
      ) : (
        <article class="ff-card friends-empty">
          <h2>{copy.emptyTitle}</h2>
          <p>{copy.emptyText}</p>
          <code>src/data/friends.ts</code>
        </article>
      )}
    </div>
  </section>
</TaxonomyLayout>
