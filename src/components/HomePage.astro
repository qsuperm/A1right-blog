---
import PageViewBadge from './PageViewBadge.astro';
import { SITE, UI, type Locale } from '../config';
import { FRIEND_LINKS, FRIEND_PAGE_COPY, FRIEND_SELF_CARD } from '../data/friends';
import {
  CATEGORY_META,
  formatDate,
  getArticleUrl,
  getArticlesByLocale,
  getCategoryUrl,
  getFriendsUrl,
  getPostsIndexUrl,
  getTagUrl,
  getUniqueTagCount,
} from '../utils/articles';

interface Props { locale: Locale; }

const { locale } = Astro.props;
const isEnglish = locale === 'en';
const homeHref = isEnglish ? '/en' : '/';
const postsHref = getPostsIndexUrl(locale);
const articles = await getArticlesByLocale(locale);
const totalTags = getUniqueTagCount(articles);
const githubUrl = SITE.githubUrl.trim();
const friendsHref = getFriendsUrl(locale);
const friendCopy = FRIEND_PAGE_COPY[locale];
const featuredFriends = FRIEND_LINKS.slice(0, 4);

const categoryCounts = articles.reduce<Record<string, number>>((acc, entry) => {
  acc[entry.data.categoryKey] = (acc[entry.data.categoryKey] ?? 0) + 1;
  return acc;
}, {});

const categories = (['web-security', 'ctf-writeup', 'agent-pentest'] as const).map((key) => ({
  key,
  name: CATEGORY_META[key][locale].name,
  count: categoryCounts[key] ?? 0,
}));

const allTags = Array.from(new Set(articles.flatMap((entry) => entry.data.tags))).slice(0, 12);
const bannerLines = [
  'We are all visitors to this time, this place.',
  'We are just passing through.',
  'Our purpose here is to observe, to learn, to grow, to love, and then we return home.',
];
const today = new Date();
const calendarYear = today.getFullYear();
const calendarMonth = today.getMonth();
const firstDay = new Date(calendarYear, calendarMonth, 1).getDay();
const daysInMonth = new Date(calendarYear, calendarMonth + 1, 0).getDate();
const calendarCells = [...Array(firstDay).fill(null), ...Array.from({ length: daysInMonth }, (_, index) => index + 1)];

const copy = isEnglish ? {
  bannerTitle: "A1right's Corner",
  role: 'Student · Security learner',
  bio: 'Hello, I am A1right. I write about Web security, CTF and Agent pentest experiments.',
  announcement: 'Announcement',
  announcementText: 'Welcome to my security notebook. New writeups and experiment notes will be added here.',
  learnMore: 'Learn more',
  archive: 'Archive',
  more: 'More',
  siteStats: 'Site statistics',
  visitPanel: 'Visit overview',
  todayViews: 'Today views',
  totalViews: 'Total views',
  liveStatus: 'Live',
  autoUpdate: 'Auto update',
  viewHint: 'Counters refresh automatically when visitors open pages.',
  posts: 'Articles', categories: 'Categories', tags: 'Tags', words: 'Total words', uptime: 'Running', activity: 'Last active',
  categoryTitle: 'Categories', tagTitle: 'Tags', days: 'days', today: 'Today',
  month: `${calendarYear}/${String(calendarMonth + 1).padStart(2, '0')}`,
} : {
  bannerTitle: 'A1right的小窝',
  role: '学生 · 安全学习者',
  bio: '你好，我是 A1right。这里记录 Web 安全、CTF 题解与 Agent 渗透实验。',
  announcement: '公告',
  announcementText: '欢迎来到我的安全笔记站，后续会持续更新题解、复盘和实验记录。',
  learnMore: '了解更多',
  archive: '归档',
  more: '更多',
  siteStats: '站点统计',
  visitPanel: '访问概览',
  todayViews: '今日访问',
  totalViews: '累计访问',
  liveStatus: '实时',
  autoUpdate: '自动更新',
  viewHint: '有访客打开页面时，统计卡片会自动刷新。', 
  posts: '文章', categories: '分类', tags: '标签', words: '总字数', uptime: '运行时长', activity: '最后活动',
  categoryTitle: '分类', tagTitle: '标签', days: '天', today: '今天',
  month: `${calendarYear}年${calendarMonth + 1}月`,
};

const totalWords = articles.reduce((sum, entry) => sum + (entry.body ?? '').split(/\s+/).length, 0);
---

<section class="fo-banner">
  <div class="fo-banner__image" aria-hidden="true"></div>
  <div class="fo-banner__dim" aria-hidden="true"></div>
  <div class="fo-banner__text">
    <h1>{copy.bannerTitle}</h1>
    <p
      class="fo-banner__typewriter"
      data-banner-typewriter
      data-banner-typewriter-lines={JSON.stringify(bannerLines)}
      aria-label={bannerLines.join(' ')}
    >
      <span class="fo-banner__typewriter-output" aria-hidden="true">
        {bannerLines.map((line) => <span class="fo-banner__typewriter-line">{line}</span>)}
      </span>
    </p>
  </div>
  <a class="fo-banner__down" href="#home-content" aria-label={isEnglish ? 'Scroll down' : '向下滚动'}>⌄</a>
  <div class="fo-waves" aria-hidden="true">
    <svg viewBox="0 24 150 28" preserveAspectRatio="none" shape-rendering="geometricPrecision">
      <defs>
        <path id="fo-gentle-wave" d="M-160 44c30 0 58-18 88-18s58 18 88 18 58-18 88-18 58 18 88 18v48h-352z"></path>
      </defs>
      <g class="fo-parallax">
        <use href="#fo-gentle-wave" x="48" y="0" opacity=".25"></use>
        <use href="#fo-gentle-wave" x="48" y="3" opacity=".5"></use>
        <use href="#fo-gentle-wave" x="48" y="5" opacity=".65"></use>
        <use href="#fo-gentle-wave" x="48" y="7" opacity=".82"></use>
      </g>
    </svg>
  </div>
</section>

<div id="home-content" class="fo-home-grid">
  <aside class="fo-sidebar fo-sidebar--left">
    <article class="fo-card fo-profile-card">
      <img class="fo-profile-card__avatar" src="/images/a1right-avatar.png" alt={SITE.author} />
      <h2>{SITE.author}</h2>
      <i class="fo-profile-card__line"></i>
      <p>{copy.role}</p>
      <p class="fo-profile-card__bio">{copy.bio}</p>
      <div class="fo-profile-card__socials">
        <a href={postsHref} aria-label={UI[locale].posts}>▤</a>
        {githubUrl && <a href={githubUrl} target="_blank" rel="noreferrer" aria-label="GitHub">⌘</a>}
        <a href={`${homeHref}#categories`} aria-label={UI[locale].categories}>⌗</a>
        <a href={`${homeHref}#tags`} aria-label={UI[locale].tags}>#</a>
      </div>
    </article>

    <article class="fo-card fo-widget">
      <h2 class="fo-widget-title">{copy.announcement}</h2>
      <p>{copy.announcementText}</p>
      <a class="fo-soft-button" href={postsHref}>{copy.learnMore}</a>
    </article>

    <article id="categories" class="fo-card fo-widget fo-list-widget">
      <h2 class="fo-widget-title">{copy.categoryTitle}</h2>
      <ul>{categories.map((item) => <li><a href={getCategoryUrl(locale, item.key)}><span>{item.name}</span><strong>{item.count}</strong></a></li>)}</ul>
    </article>

    <article id="tags" class="fo-card fo-widget">
      <h2 class="fo-widget-title">{copy.tagTitle}</h2>
      <div class="fo-tag-cloud">{allTags.map((tag) => <a href={getTagUrl(locale, tag)}>#{tag}</a>)}</div>
    </article>
  </aside>

  <div class="fo-main-column">
    <nav class="fo-card fo-category-bar" aria-label={UI[locale].categories}>
      <a class="fo-category-pill fo-category-pill--active" href={homeHref}>⌂</a>
      <a class="fo-category-pill" href={postsHref}>{copy.archive}<small>{articles.length}</small></a>
      <i></i>
      {categories.map((item) => <a class="fo-category-pill" href={getCategoryUrl(locale, item.key)}>{item.name}<small>{item.count}</small></a>)}
      <a class="fo-category-pill fo-category-pill--more" href={isEnglish ? '/en/categories' : '/categories'}>{copy.more} ›</a>
    </nav>

    <section class="fo-post-list">
      {articles.map((post) => (
        <article class="fo-card fo-post-card">
          <div class="fo-post-card__content">
            <h2><a href={getArticleUrl(post)}>{post.data.title}</a></h2>
            <div class="fo-post-card__meta">
              {post.data.pinned && <span class="fo-pinned">▣ {UI[locale].sticky}</span>}
              <time datetime={post.data.publishedAt.toISOString()}>▢ {formatDate(post.data.publishedAt, locale)}</time>
              <a href={getCategoryUrl(locale, post.data.categoryKey)}>▤ {post.data.category}</a>
              <PageViewBadge path={getArticleUrl(post)} locale={locale} />
            </div>
            <p>{post.data.excerpt}</p>
            <div class="fo-post-card__tags">{post.data.tags.map((tag) => <a href={getTagUrl(locale, tag)}>#{tag}</a>)}</div>
          </div>
          <a class="fo-post-card__cover" href={getArticleUrl(post)} aria-label={post.data.title}>
            <img src={post.data.cover} alt={post.data.coverAlt || post.data.title} loading="lazy" /><span>›</span>
          </a>
        </article>
      ))}
    </section>
  </div>

  <aside class="fo-sidebar fo-sidebar--right">
    <article class="fo-card fo-visit-hero">
      <div class="fo-visit-hero__head">
        <p class="fo-visit-hero__eyebrow">{copy.visitPanel}</p>
        <span class="fo-visit-hero__status">{copy.liveStatus} · {copy.autoUpdate}</span>
      </div>
      <div class="fo-visit-hero__grid">
        <section class="fo-visit-metric fo-visit-metric--today">
          <span class="fo-visit-metric__icon" aria-hidden="true">✦</span>
          <div class="fo-visit-metric__body">
            <p>{copy.todayViews}</p>
            <PageViewBadge daily locale={locale} mode="value" />
          </div>
        </section>
        <section class="fo-visit-metric fo-visit-metric--total">
          <span class="fo-visit-metric__icon" aria-hidden="true">◔</span>
          <div class="fo-visit-metric__body">
            <p>{copy.totalViews}</p>
            <PageViewBadge total locale={locale} mode="value" />
          </div>
        </section>
      </div>
      <p class="fo-visit-hero__hint">{copy.viewHint}</p>
    </article>

    <article class="fo-card fo-widget fo-stats-widget">
      <h2 class="fo-widget-title">{copy.siteStats}</h2>
      <dl>
        <div><dt>▤ {copy.posts}</dt><dd>{articles.length}</dd></div>
        <div><dt>□ {copy.categories}</dt><dd>{categories.length}</dd></div>
        <div><dt>◇ {copy.tags}</dt><dd>{totalTags}</dd></div>
        <div><dt>▧ {copy.words}</dt><dd>{totalWords.toLocaleString()}</dd></div>
        <div><dt>✦ {copy.todayViews}</dt><dd><PageViewBadge daily locale={locale} mode="full" /></dd></div>
        <div><dt>◔ {copy.totalViews}</dt><dd><PageViewBadge total locale={locale} mode="full" /></dd></div>
        <div><dt>◴ {copy.uptime}</dt><dd>1 {copy.days}</dd></div>
        <div><dt>⌁ {copy.activity}</dt><dd>{copy.today}</dd></div>
      </dl>
    </article>

    <article class="fo-card fo-widget fo-friends-entry">
      <div class="fo-friends-entry__head">
        <h2 class="fo-widget-title">{friendCopy.entryTitle}</h2>
      </div>
      <div class="fo-friends-entry__avatars" aria-hidden="true">
        {(featuredFriends.length > 0 ? featuredFriends : [FRIEND_SELF_CARD]).map((item) => (
          <img src={item.avatar} alt="" loading="lazy" />
        ))}
      </div>
      <div class="fo-friends-entry__meta">
        <strong>{FRIEND_LINKS.length}</strong>
        <span>{locale === 'en' ? 'listed sites' : '已收录站点'}</span>
      </div>
      <a class="fo-soft-button" href={friendsHref}>{friendCopy.entryAction}</a>
    </article>

    <article class="fo-card fo-calendar">
      <header><button type="button" aria-label="Previous month">‹</button><h2>{copy.month}</h2><button type="button" aria-label="Next month">›</button></header>
      <div class="fo-calendar__week"><span>{isEnglish ? 'S' : '日'}</span><span>{isEnglish ? 'M' : '一'}</span><span>{isEnglish ? 'T' : '二'}</span><span>{isEnglish ? 'W' : '三'}</span><span>{isEnglish ? 'T' : '四'}</span><span>{isEnglish ? 'F' : '五'}</span><span>{isEnglish ? 'S' : '六'}</span></div>
      <div class="fo-calendar__days">{calendarCells.map((day) => day ? <span class:list={{ 'is-today': day === today.getDate() }}>{day}</span> : <span></span>)}</div>
    </article>
  </aside>
</div>

<script>
  const pause = (duration: number) => new Promise<void>((resolve) => window.setTimeout(resolve, duration));

  const animateBannerTypewriter = async (element: HTMLElement) => {
    if (element.dataset.typewriterReady === 'true') return;

    const rawLines = element.dataset.bannerTypewriterLines;
    const output = element.querySelector<HTMLElement>('.fo-banner__typewriter-output');
    if (!rawLines || !output) return;

    let lines: string[];
    try {
      lines = JSON.parse(rawLines);
    } catch {
      return;
    }

    if (!Array.isArray(lines) || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    element.dataset.typewriterReady = 'true';
    await document.fonts.ready;
    output.replaceChildren();
    await pause(520);

    for (const [lineIndex, line] of lines.entries()) {
      const lineElement = document.createElement('span');
      lineElement.className = 'fo-banner__typewriter-line is-typing';
      output.append(lineElement);

      for (const character of Array.from(line)) {
        lineElement.textContent += character;
        await pause(character === ',' ? 112 : character === '.' ? 180 : character === ' ' ? 22 : 36);
      }

      lineElement.classList.remove('is-typing');
      if (lineIndex < lines.length - 1) await pause(360);
    }

    output.lastElementChild?.classList.add('is-typing');
  };

  const bindBannerTypewriter = () => {
    document.querySelectorAll<HTMLElement>('[data-banner-typewriter]').forEach((element) => {
      void animateBannerTypewriter(element);
    });
  };

  bindBannerTypewriter();
  document.addEventListener('astro:page-load', bindBannerTypewriter);
</script>
